# .dockerignore
# Ignore node_modules directories in both root and frontend
node_modules
frontend/node_modules

# Ignore the frontend build output, as it's built inside the container
frontend/dist

# Ignore the .env file, as it's copied explicitly for the backend
.env

# Ignore Docker-related files themselves (now in devops directory)
devops/Dockerfile*
docker-compose.yml

# Ignore Git-related files
.git
.gitignore

# Ignore common editor/OS files
.DS_Store
npm-debug.log
yarn-debug.log
yarn-error.log
.vscode